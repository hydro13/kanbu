# Kanbu Self-Hosted Configuration
#
# Copy this file to .env and update the values.
# IMPORTANT: Change all default passwords before deploying!

# ═══════════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════════
POSTGRES_USER=kanbu
POSTGRES_PASSWORD=kanbu_secret_change_me
POSTGRES_DB=kanbu

# ═══════════════════════════════════════════════════════════════════
# API Server
# ═══════════════════════════════════════════════════════════════════

# JWT secret for authentication (generate a strong random string!)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-me

# CORS origin - URL where the web frontend is hosted
CORS_ORIGIN=http://localhost

# API port (internal, change if 3001 is in use)
API_PORT=3001

# ═══════════════════════════════════════════════════════════════════
# Web Frontend
# ═══════════════════════════════════════════════════════════════════

# API URL as seen from the browser
# For local: http://localhost:3001
# For server: https://api.yourdomain.com
VITE_API_URL=http://localhost:3001

# Web port (default 80, use 8080 if 80 requires root)
WEB_PORT=80

# ═══════════════════════════════════════════════════════════════════
# Backup Configuration
# ═══════════════════════════════════════════════════════════════════

# Storage backend: 'local' (default for self-hosted)
BACKUP_STORAGE=local

# Local backup path (will be created automatically)
# This should be a persistent volume in Docker
BACKUP_LOCAL_PATH=/data/backups

# PostgreSQL container pattern (for dynamic container names)
# Default: 'postgres-' works with most deployments
POSTGRES_CONTAINER_PATTERN=postgres-

# ═══════════════════════════════════════════════════════════════════
# Knowledge Graph (docker-compose.openclaw.yml only)
# ═══════════════════════════════════════════════════════════════════

# AI provider for Graphiti entity extraction
# Choose: openai (recommended) or anthropic
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ═══════════════════════════════════════════════════════════════════
# GitHub Integration (optional)
# Full setup guide: docs/GITHUB-INTEGRATION.md
# ═══════════════════════════════════════════════════════════════════

# Create a GitHub App at: https://github.com/settings/apps/new
# Set webhook URL to: https://yourdomain.com/api/webhooks/github
# Set callback URL to: https://yourdomain.com/api/github/callback
GITHUB_APP_ID=
GITHUB_APP_NAME=kanbu-yourname
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
# Private key from GitHub App (newlines as \n):
GITHUB_PRIVATE_KEY=
GITHUB_CALLBACK_URL=https://yourdomain.com/api/github/callback

# ═══════════════════════════════════════════════════════════════════
# OpenClaw Agent Integration (optional)
# ═══════════════════════════════════════════════════════════════════

# URL of your OpenClaw gateway (leave empty to disable agent dispatch)
# Example: http://100.88.203.92:18789  (Tailscale IP of your OpenClaw machine)
OPENCLAW_GATEWAY_URL=

# Bearer token for OpenClaw gateway authentication
OPENCLAW_GATEWAY_TOKEN=
